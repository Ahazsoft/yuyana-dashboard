// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  // url and directUrl should be set via environment variables
}

// ----- ENUMS -----
enum UserRole {
  ADMIN
  SALES
  MARKETING
  CUSTOMER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATING
  WON
  LOST
  ARCHIVED
}

enum BookingStatus {
  INQUIRY
  TENTATIVE
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  CHAPA
  STRIPE
  PAYPAL
  MANUAL
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  PAUSED
}

enum SubscriptionStatus {
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique // SHA-256 hash of the raw refresh token
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ----- NEW CRM TABLES -----
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      UserRole
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  customer        Customer?
  sales           Sales?
  marketing       Marketing?
  admin           Admin?
  bookings        Booking[]
  emailLogs       EmailLog[]
  leads           Lead[]
  segments        Segment[]
  automationRules AutomationRule[]

  @@index([email])
  @@index([role])
  @@index([active])
}

// ----- NEW CRM TABLES -----
model Customer {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  bookings Booking[]
  reviews  Review[]

  leads       Lead[]
  tourRatings TourRating[]
}

// ----- NEW CRM TABLES -----
model Sales {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  leads Lead[]
}

// ----- NEW CRM TABLES -----
model Marketing {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  campaigns Campaign[]
  segments  Segment[]
}

// ----- NEW CRM TABLES -----
model Admin {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  leads     Lead[]
  bookings  Booking[]
  campaigns Campaign[]
  emailLogs EmailLog[]
}

// ----- EXISTING TOUR TABLES (with added relation to Review) -----
model TourPackage {
  id              String   @id @default(uuid()) @db.Uuid 
  slugUrl         String   @unique @map("slug_url")
  imageUrl        String?  @map("image_url")
  tourTitle       String   @map("tour_title")
  tourDescription String?  @map("tour_description")
  tourDuration    Int?     @map("tour_duration")
  tourDestination String   @map("tour_destination")
  tourPrice       Json?    @map("tour_price") // JSONB
  isPublished     Boolean  @default(false) @map("is_published")
  included        String[]
  excluded        String[]
  tourDocumentUrl String?  @map("tour_document_url")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tourPlanDays TourPlanDay[]
  bookings     Booking[] // relation to bookings
  reviews      Review[] // relation to reviews (added)
  ratings      TourRating[] // relation for simple ratings

  @@map("tour_packages")
}

model TourPlanDay {
  id            Int      @id @default(autoincrement())
  tourPackageId String   @map("tour_package_id") @db.Uuid
  dayNumber     Int      @map("day_number")
  title         String?
  description   String?
  items         String[]
  boldtext      String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tourPackage TourPackage @relation(fields: [tourPackageId], references: [id], onDelete: Cascade)

  @@unique([tourPackageId, dayNumber])
  @@map("tour_plan_days")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String? // nullable for system/unauthenticated actions
  action     String // e.g. "lead.status_changed", "user.login", "campaign.sent"
  entityType String? // e.g. "Lead", "Booking", "User"
  entityId   String? // the id of the lead where the status were changed
  ipAddress  String?
  userAgent  String?
  meta       Json? // additional context
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model ContactMessage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  name      String
  email     String
  message   String
}

model Booking {
  id               String        @id @default(cuid())
  customerId       String
  tourPackageId    String        @map("tour_package_id") @db.Uuid
  userId           String // Added missing field
  numberOfGuests   Int
  status           BookingStatus @default(INQUIRY)
  price            Float // snapshot of price at booking time (HLD requirement)
  currency         String        @default("ETB")
  bookingDate      DateTime      @default(now())
  travelDate       DateTime?
  notes            String?
  paymentLinkUrl   String? // generated payment link URL
  paymentReference String? // provider's payment reference ID
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tourPackage TourPackage @relation(fields: [tourPackageId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  payments    Payment[]
  admin       Admin?      @relation(fields: [adminId], references: [id])
  adminId     String?

  @@index([customerId])
  @@index([tourPackageId])
  @@index([userId])
  @@index([status])
  @@index([travelDate])
}

model EmailLog {
  id             String    @id @default(cuid())
  campaignId     String?
  userId         String
  recipientEmail String
  subject        String?
  status         String    @default("pending") // pending, sent, bounced, failed
  openedAt       DateTime?
  clickedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  user     User      @relation(fields: [userId], references: [id])
  admin    Admin?    @relation(fields: [adminId], references: [id])
  adminId  String?

  @@index([campaignId])
  @@index([userId])
  @@index([recipientEmail])
  @@index([status])
}

model Review {
  id            String   @id @default(cuid())
  customerId    String? // if the reviewer is a registered customer
  tourPackageId String?  @map("tour_package_id") @db.Uuid // 🔹 must match UUID type of TourPackage.id
  name          String // name of the reviewer (always filled)
  email         String // email of the reviewer
  rating        Int // 1-5
  comment       String
  approved      Boolean  @default(false) // admin approval before public display
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  anonymous     Boolean  @default(false)

  customer    Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  tourPackage TourPackage? @relation(fields: [tourPackageId], references: [id], onDelete: SetNull)

  @@index([tourPackageId])
  @@index([approved])
  @@map("reviews")
}

model Lead {
  id          String   @id @default(cuid())
  customerId  String?
  userId      String? // sales user id 
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer   Customer?  @relation(fields: [customerId], references: [id])
  user       User?      @relation(fields: [userId], references: [id])
  leadStatus LeadStatus
  sales      Sales?     @relation(fields: [salesId], references: [id])
  salesId    String?
  admin      Admin?     @relation(fields: [adminId], references: [id])
  adminId    String?
  segment    Segment?   @relation(fields: [segmentId], references: [id])
  segmentId  String?
}

model TourRating {
  id         String   @id @default(cuid()) 
  tourId     String @db.Uuid
  customerId String
  rating     Int
  createdAt  DateTime @default(now())

  tour_package TourPackage @relation(fields: [tourId], references: [id])
  customer     Customer    @relation(fields: [customerId], references: [id])
}

model Segment {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leads       Lead[]
  user        User?      @relation(fields: [userId], references: [id])
  marketing   Marketing? @relation(fields: [marketingId], references: [id])
  marketingId String?
  campaigns   Campaign[]
}

model AutomationRule {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  condition String
  action    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model Campaign {
  id        String   @id @default(cuid())
  segmentId String?
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  segment     Segment?   @relation(fields: [segmentId], references: [id])
  marketing   Marketing? @relation(fields: [marketingId], references: [id])
  marketingId String?
  admin       Admin?     @relation(fields: [adminId], references: [id])
  adminId     String?
  emailLogs   EmailLog[]
}

model Payment {
  id            String          @id @default(cuid())
  bookingId     String
  amount        Float
  currency      String          @default("ETB")
  status        PaymentStatus   @default(PENDING)
  provider      PaymentProvider
  transactionId String?
  paidAt        DateTime?
  createdAt     DateTime        @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status])
}
