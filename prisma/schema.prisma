generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model TourPackage {
  id               String         @id @default(uuid()) @db.Uuid
  slugUrl          String         @unique @map("slug_url")
  imageUrl         String?        @map("image_url")
  tourTitle        String         @map("tour_title")
  tourDescription  String?        @map("tour_description")
  tourDuration     Int?           @map("tour_duration")
  tourDestination  String         @map("tour_destination")   // now required TEXT
  tourPrice        Json?          @map("tour_price")         // JSONB for flexible pricing
  tourRating       Float?         @map("tour_rating")
  included         String[]                                  // optional list
  excluded         String[]                                  // optional list
  tourDocumentUrl  String?        @map("tour_document_url")
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  tourPlanDays     TourPlanDay[]

  @@map("tour_packages")
}

model TourPlanDay {
  id              Int       @id @default(autoincrement())
  tourPackageId   String    @map("tour_package_id") @db.Uuid
  dayNumber       Int       @map("day_number")                // now required, used for ordering
  title           String?
  description     String?
  items           String[]
  boldtext        String?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tourPackage     TourPackage @relation(fields: [tourPackageId], references: [id], onDelete: Cascade)

  @@unique([tourPackageId, dayNumber])                         // ensures one day per number per tour
  @@map("tour_plan_days")
}