// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  // url and directUrl should be set via environment variables
}

// ----- ENUMS -----
enum UserRole {
  ADMIN
  SALES
  MARKETING
  VIEWER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATING
  WON
  LOST
  ARCHIVED
}

enum BookingStatus {
  INQUIRY
  TENTATIVE
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  CHAPA
  STRIPE
  PAYPAL
  MANUAL
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  PAUSED
}

enum SubscriptionStatus {
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
}

// ----- EXISTING TOUR TABLES (with added relation to Review) -----
model TourPackage {
  id              String   @id @default(uuid()) @db.Uuid
  slugUrl         String   @unique @map("slug_url")
  imageUrl        String?  @map("image_url")
  tourTitle       String   @map("tour_title")
  tourDescription String?  @map("tour_description")
  tourDuration    Int?     @map("tour_duration")
  tourDestination String   @map("tour_destination")
  tourPrice       Json?    @map("tour_price") // JSONB
  isPublished     Boolean  @default(false) @map("is_published")
  included        String[]
  excluded        String[]
  tourDocumentUrl String?  @map("tour_document_url")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tourPlanDays    TourPlanDay[]
  bookings        Booking[] // relation to bookings
  reviews         Review[] // relation to reviews (added)
  ratings         TourRating[]    // relation for simple ratings
  @@map("tour_packages")
}

model TourPlanDay {
  id            Int      @id @default(autoincrement())
  tourPackageId String   @map("tour_package_id") @db.Uuid
  dayNumber     Int      @map("day_number")
  title         String?
  description   String?
  items         String[]
  boldtext      String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tourPackage TourPackage @relation(fields: [tourPackageId], references: [id], onDelete: Cascade)

  @@unique([tourPackageId, dayNumber])
  @@map("tour_plan_days")
}

// ----- NEW CRM TABLES -----
model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  password             String
  name                 String
  role                 UserRole  @default(VIEWER)
  active               Boolean   @default(true)
  lastLoginAt          DateTime?
  failedLoginCount     Int       @default(0)
  lockedUntil          DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  customers      Customer[]
  leads          Lead[]
  bookings       Booking[]
  campaigns      Campaign[]
  emailLogs      EmailLog[]
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]
  segments       Segment[]
  automationRules AutomationRule[]

  @@index([email])
  @@index([role])
  @@index([active])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique // SHA-256 hash of the raw refresh token
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  // nullable for system/unauthenticated actions
  action     String   // e.g. "lead.status_changed", "user.login", "campaign.sent"
  entityType String?  // e.g. "Lead", "Booking", "User"
  entityId   String?
  ipAddress  String?
  userAgent  String?
  meta       Json?    // additional context
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model ContactMessage {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  name        String
  email       String
  message     String
}

model Booking {
  id                String        @id @default(cuid())
  customerId        String
  tourPackageId     String        @map("tour_package_id") @db.Uuid
  userId            String        // Added missing field
  numberOfGuests    Int
  status            BookingStatus @default(INQUIRY)
  agreedPrice       Float         // snapshot of price at booking time (HLD requirement)
  totalPrice        Float
  currency          String        @default("ETB")
  bookingDate       DateTime      @default(now())
  travelDate        DateTime?
  notes             String?
  paymentLinkUrl    String?       // generated payment link URL
  paymentReference  String?       // provider's payment reference ID
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  customer    Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tourPackage TourPackage       @relation(fields: [tourPackageId], references: [id])
  user        User              @relation(fields: [userId], references: [id])
  payments    Payment[]
  activities  BookingActivity[]

  @@index([customerId])
  @@index([tourPackageId])
  @@index([userId])
  @@index([status])
  @@index([travelDate])
}

model Campaign {
  id            String         @id @default(cuid())
  name          String
  status        CampaignStatus @default(DRAFT)
  description   String?
  subject       String?        // email subject
  content       String?        // email body (HTML or text)
  segmentId     String?        // linked Segment model
  targetSegment Json?          // inline criteria (used if segmentId is null)
  recipientCount Int           @default(0)
  createdBy     String
  scheduledDate DateTime?
  sentDate      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user      User       @relation(fields: [createdBy], references: [id])
  segment   Segment?   @relation(fields: [segmentId], references: [id])
  emailLogs EmailLog[]

  @@index([createdBy])
  @@index([status])
  @@index([segmentId])
  @@index([scheduledDate])
}

model EmailLog {
  id             String    @id @default(cuid())
  campaignId     String?
  userId         String
  recipientEmail String
  subject        String?
  status         String    @default("pending") // pending, sent, bounced, failed
  openedAt       DateTime?
  clickedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  user     User      @relation(fields: [userId], references: [id])

  @@index([campaignId])
  @@index([userId])
  @@index([recipientEmail])
  @@index([status])
}

model Review {
  id            String   @id @default(cuid())
  customerId    String? // if the reviewer is a registered customer
  tourPackageId String?  @map("tour_package_id") @db.Uuid // 🔹 must match UUID type of TourPackage.id
  name          String // name of the reviewer (always filled)
  email         String // email of the reviewer
  rating        Int // 1-5
  comment       String
  approved      Boolean  @default(false) // admin approval before public display
  verified      Boolean  @default(false) // true if reviewer was authenticated (customerId set)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer    Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  tourPackage TourPackage? @relation(fields: [tourPackageId], references: [id], onDelete: SetNull)

  @@index([tourPackageId])
  @@index([approved])
  @@map("reviews")
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  userId      String?  // Added missing field
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings    Booking[]
  reviews     Review[]
  ratings     TourRating[]
}

model Lead {
  id          String   @id @default(cuid())
  customerId  String
  userId      String?  // Added missing field
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer @relation(fields: [customerId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])
  leadActivity LeadActivity[] // Added opposite relation
}

model TourRating {
  id          String   @id @default(cuid())
  tourId      String
  customerId  String
  rating      Int
  createdAt   DateTime @default(now())

  tour        Tour     @relation(fields: [tourId], references: [id])
  customer    Customer @relation(fields: [customerId], references: [id])
}

model Segment {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leads       Lead[]
  user        User?    @relation(fields: [userId], references: [id])
}

model AutomationRule {
  id          String   @id @default(cuid())
  name        String
  condition   String
  action      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User?    @relation(fields: [userId], references: [id])
}

model Campaign {
  id          String   @id @default(cuid())
  segmentId   String?
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  segment     Segment? @relation(fields: [segmentId], references: [id])
}

model Review {
  id          String   @id @default(cuid())
  customerId  String?
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer? @relation(fields: [customerId], references: [id])
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings    Booking[]
  reviews     Review[]
  ratings     TourRating[]
}